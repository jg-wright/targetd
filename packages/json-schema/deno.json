{
  "name": "@targetd/json-schema",
  "version": "7.0.2",
  "description": "Generate JSON Schema from @targetd/api Data instances for API documentation and validation.",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "imports": {
    "@es-toolkit/es-toolkit": "jsr:@es-toolkit/es-toolkit@^1.49.0",
    "@targetd/api": "jsr:@targetd/api@^10.0.3",
    "@types/yargs": "npm:@types/yargs@^17.0.35",
    "yargs": "npm:yargs@^18.0.0",
    "zod": "npm:zod@~4.4.3"
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-import-prefix",
        "no-unversioned-import"
      ]
    }
  },
  "fmt": {
    "semiColons": false,
    "singleQuote": true
  },
  "tasks": {
    "pwd": "echo $(pwd)",
    "test": "deno test --allow-all --trace-leaks"
  },
  "publish": {
    "include": [
      "deno.json",
      "src/",
      "LICENSE",
      "README.md"
    ]
  }
}
